{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "node": "20.19.4",
      "env": {
        "EXPO_NO_BUN": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "node": "20.19.4",
      "env": {
        "EXPO_NO_BUN": "1"
      }
    },
    "production": {
      "distribution": "store",
      "autoIncrement": true,
      "ios": {
        "simulator": false
      },
      "node": "20.19.4",
      "env": {
        "EXPO_NO_BUN": "1",
        "EXPO_PUBLIC_ENV": "production"
      }
    },
    "production-simulator": {
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "node": "20.19.4",
      "env": {
        "EXPO_NO_BUN": "1",
        "EXPO_PUBLIC_ENV": "production"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
